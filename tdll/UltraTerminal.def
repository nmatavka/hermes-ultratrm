LIBRARY   ULTRATERMINAL

EXPORTS
	; tdll.c
	InitInstance
    MessageLoop

	; pageext.c
        DllCanUnloadNow     PRIVATE
        DllGetClassObject   PRIVATE

	; sesshdl.c
	sessQueryTranslateHdl
	sessQuerySysFileHdl

	; sf.c
	sfGetSessionItem
	sfPutSessionItem

    ; Rexx compatibility loaders
    ;
    ; The full Rxha*/RxZoc* surface is emitted from tdll/rexxapis.c via
    ; __declspec(dllexport) so it can be generated from the shared function
    ; tables without hand-maintaining hundreds of lines here. The stable loader
    ; entry points remain listed explicitly in the module definition file.
    haLoadFuncs
    haDropFuncs
    utLoadRexxApis
    utDropRexxApis
